{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup",
        "hooks": [
          { "type": "command", "command": "\"${CLAUDE_PLUGIN_ROOT}\"/hooks/verify-and-inject.sh", "timeout": 15 }
        ]
      },
      {
        "matcher": "resume",
        "hooks": [
          { "type": "command", "command": "\"${CLAUDE_PLUGIN_ROOT}\"/hooks/verify-and-inject.sh", "timeout": 15 }
        ]
      },
      {
        "matcher": "clear",
        "hooks": [
          { "type": "command", "command": "\"${CLAUDE_PLUGIN_ROOT}\"/hooks/verify-and-inject.sh", "timeout": 15 }
        ]
      },
      {
        "matcher": "compact",
        "hooks": [
          { "type": "command", "command": "\"${CLAUDE_PLUGIN_ROOT}\"/hooks/verify-and-inject.sh", "timeout": 15 }
        ]
      }
    ]
  }
}
